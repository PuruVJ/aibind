{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "package": {
      "dependsOn": ["^package"],
      "outputs": ["dist/**", ".svelte-kit/**"]
    },
    "build": {
      "dependsOn": ["^package"],
      "outputs": [".svelte-kit/**", ".next/**", ".output/**", ".vinxi/**", ".vitepress/dist/**"]
    },
    "test": {
      "dependsOn": ["^package"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
