{
  "name": "@aibind/sveltekit",
  "version": "0.12.0",
  "description": "AI SDK bindings for SvelteKit — streaming, structured output, agents, server handlers, and remote functions",
  "license": "MIT",
  "keywords": [
    "svelte",
    "sveltekit",
    "ai",
    "ai-sdk",
    "llm",
    "streaming",
    "openai",
    "anthropic",
    "agents",
    "svelte5"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puruvj/aibind"
  },
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./server": {
      "types": "./src/lib/server/index.ts",
      "default": "./src/lib/server/index.ts"
    },
    "./agent": {
      "types": "./src/lib/agent.ts",
      "svelte": "./src/lib/agent.ts",
      "default": "./src/lib/agent.ts"
    },
    "./remote": {
      "types": "./src/lib/remote/index.ts",
      "default": "./src/lib/remote/index.ts"
    },
    "./markdown": {
      "types": "./src/lib/markdown.ts",
      "svelte": "./src/lib/markdown.ts",
      "default": "./src/lib/markdown.ts"
    },
    "./history": {
      "types": "./src/lib/history.ts",
      "svelte": "./src/lib/history.ts",
      "default": "./src/lib/history.ts"
    },
    "./project": {
      "types": "./src/lib/project.ts",
      "svelte": "./src/lib/project.ts",
      "default": "./src/lib/project.ts"
    },
    "./artifact": {
      "types": "./src/lib/artifact.ts",
      "default": "./src/lib/artifact.ts"
    }
  },
  "publishConfig": {
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "svelte": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "./agent": {
        "types": "./dist/agent.d.ts",
        "svelte": "./dist/agent.js",
        "default": "./dist/agent.js"
      },
      "./remote": {
        "types": "./dist/remote/index.d.ts",
        "default": "./dist/remote/index.js"
      },
      "./markdown": {
        "types": "./dist/markdown.d.ts",
        "svelte": "./dist/markdown.js",
        "default": "./dist/markdown.js"
      },
      "./history": {
        "types": "./dist/history.d.ts",
        "svelte": "./dist/history.js",
        "default": "./dist/history.js"
      },
      "./project": {
        "types": "./dist/project.d.ts",
        "svelte": "./dist/project.js",
        "default": "./dist/project.js"
      },
      "./artifact": {
        "types": "./dist/artifact.d.ts",
        "default": "./dist/artifact.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite dev",
    "package": "vite build && svelte-package -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aibind/svelte": "workspace:*",
    "@aibind/core": "workspace:*",
    "@aibind/markdown": "workspace:*"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.53.0",
    "ai": "^6.0.0",
    "svelte": "^5.53.0"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "ai": "^6.0.108",
    "svelte": "^5.53.6",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "valibot": "^1.2.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
