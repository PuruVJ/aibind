{
  "name": "@aibind/sqlite",
  "version": "0.4.0",
  "description": "SQLite-backed StreamStore and ConversationStore for @aibind — works with Turso, libsql, and better-sqlite3",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "turso",
    "libsql",
    "aibind",
    "stream-store",
    "conversation-store",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puruvj/aibind"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@aibind/core": "*"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "tsup"
  },
  "devDependencies": {
    "@aibind/core": "workspace:*",
    "@types/better-sqlite3": "^7.6.0",
    "better-sqlite3": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
