{
  "name": "@aibind/service-worker",
  "version": "2.0.0",
  "description": "Service Worker backend for @aibind — run AI streaming with zero server infrastructure using IndexedDB",
  "license": "MIT",
  "keywords": [
    "service-worker",
    "pwa",
    "offline",
    "indexeddb",
    "aibind",
    "ai",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puruvj/aibind"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@aibind/core": "*",
    "ai": "*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "tsup"
  },
  "devDependencies": {
    "@aibind/core": "workspace:*",
    "ai": "^4.0.0",
    "fake-indexeddb": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
