{
  "name": "svai",
  "version": "0.1.0",
  "type": "module",
  "svelte": "./dist/index.svelte.js",
  "types": "./dist/index.svelte.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.svelte.d.ts",
      "svelte": "./dist/index.svelte.js",
      "default": "./dist/index.svelte.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./chat": {
      "types": "./dist/chat/index.d.ts",
      "svelte": "./dist/chat/index.js",
      "default": "./dist/chat/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "svelte": "./dist/agent/index.js",
      "default": "./dist/agent/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && pnpm package",
    "package": "svelte-package -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.53.0",
    "ai": "^6.0.0",
    "svelte": "^5.53.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@ai-sdk/svelte": "^4.0.78"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.53",
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^25.3.3",
    "ai": "^6.0.108",
    "svelte": "^5.53.6",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
