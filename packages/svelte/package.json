{
  "name": "@aibind/svelte",
  "version": "0.1.0",
  "description": "AI SDK bindings for Svelte 5 — reactive streaming, structured output, and agents",
  "license": "MIT",
  "keywords": [
    "svelte",
    "ai",
    "ai-sdk",
    "llm",
    "streaming",
    "openai",
    "anthropic",
    "agents",
    "svelte5"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puruvj/aibind"
  },
  "type": "module",
  "svelte": "./src/lib/index.svelte.ts",
  "types": "./src/lib/index.svelte.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.svelte.ts",
      "svelte": "./src/lib/index.svelte.ts",
      "default": "./src/lib/index.svelte.ts"
    },
    "./agent": {
      "types": "./src/lib/agent/index.ts",
      "svelte": "./src/lib/agent/index.ts",
      "default": "./src/lib/agent/index.ts"
    }
  },
  "publishConfig": {
    "svelte": "./dist/index.svelte.js",
    "types": "./dist/index.svelte.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.svelte.d.ts",
        "svelte": "./dist/index.svelte.js",
        "default": "./dist/index.svelte.js"
      },
      "./agent": {
        "types": "./dist/agent/index.d.ts",
        "svelte": "./dist/agent/index.js",
        "default": "./dist/agent/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && pnpm package",
    "package": "svelte-package -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aibind/common": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "svelte": "^5.53.0"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@valibot/to-json-schema": "^1.5.0",
    "ai": "^6.0.108",
    "svelte": "^5.53.6",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "valibot": "^1.2.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.76"
  }
}
