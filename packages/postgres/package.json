{
  "name": "@aibind/postgres",
  "version": "0.4.0",
  "description": "PostgreSQL-backed StreamStore and ConversationStore for @aibind — works with pg, postgres.js, Neon, Supabase, and more",
  "license": "MIT",
  "keywords": ["postgres", "postgresql", "neon", "supabase", "aibind", "stream-store", "conversation-store", "ai"],
  "repository": {
    "type": "git",
    "url": "https://github.com/puruvj/aibind"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "README.md"],
  "peerDependencies": {
    "@aibind/core": "*"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": true },
    "postgres": { "optional": true },
    "@neondatabase/serverless": { "optional": true }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "tsup"
  },
  "devDependencies": {
    "@aibind/core": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
