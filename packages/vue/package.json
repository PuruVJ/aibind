{
  "name": "@aibind/vue",
  "version": "0.11.2",
  "description": "AI SDK bindings for Vue 3 — reactive composables for streaming, structured output, and agents",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "ai",
    "ai-sdk",
    "llm",
    "streaming",
    "openai",
    "anthropic",
    "agents",
    "composables"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puruvj/aibind"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.ts",
      "import": "./dist/markdown/index.js"
    },
    "./history": {
      "types": "./dist/history/index.d.ts",
      "import": "./dist/history/index.js"
    },
    "./project": {
      "types": "./dist/project/index.d.ts",
      "import": "./dist/project/index.js"
    },
    "./artifact": {
      "types": "./dist/artifact.d.ts",
      "import": "./dist/artifact.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "agent": [
        "dist/agent/index.d.ts"
      ],
      "markdown": [
        "dist/markdown/index.d.ts"
      ],
      "history": [
        "dist/history/index.d.ts"
      ],
      "project": [
        "dist/project/index.d.ts"
      ],
      "artifact": [
        "dist/artifact.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "tsup"
  },
  "dependencies": {
    "@aibind/core": "workspace:*",
    "@aibind/markdown": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@valibot/to-json-schema": "^1.5.0",
    "ai": "^6.0.108",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "valibot": "^1.2.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "zod": "^3.25.76"
  }
}
