{
  "name": "@aibind/solidstart",
  "version": "0.1.0",
  "description": "AI SDK bindings for SolidStart — reactive hooks with defaults, server handlers, and agents",
  "license": "MIT",
  "keywords": [
    "solid",
    "solidjs",
    "solidstart",
    "ai",
    "ai-sdk",
    "llm",
    "streaming",
    "openai",
    "anthropic",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puruvj/aibind"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js",
      "require": "./dist/agent.cjs"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js",
      "require": "./dist/markdown.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aibind/solid": "workspace:*",
    "@aibind/common": "workspace:*",
    "@aibind/markdown": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "ai": "^6.0.108",
    "solid-js": "^1.9.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
