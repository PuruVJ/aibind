{
  "name": "@aibind/core",
  "version": "0.11.0",
  "description": "Shared internal utilities for @aibind packages",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/puruvj/aibind"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./artifact": {
      "types": "./src/artifact-entry.ts",
      "default": "./src/artifact-entry.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./artifact": {
        "types": "./dist/artifact-entry.d.ts",
        "default": "./dist/artifact-entry.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@valibot/to-json-schema": "^1.5.0",
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@valibot/to-json-schema": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "tsup"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@valibot/to-json-schema": "^1.5.0",
    "ai": "^6.0.108",
    "tsup": "^8.5.1",
    "vitest": "^3.0.0"
  }
}
