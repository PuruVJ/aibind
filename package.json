{
  "name": "svai-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --filter sveltekit-demo dev",
    "dev:nuxt": "pnpm -r --filter nuxt-demo dev",
    "dev:solid": "pnpm -r --filter solidstart-demo dev",
    "package": "turbo run package",
    "build": "turbo run build",
    "test": "turbo run test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm package && changeset publish",
    "release:jsr": "pnpm package && node scripts/publish-jsr.js",
    "sizes": "pnpm package && node scripts/measure-sizes.js",
    "bench": "pnpm --filter @aibind/markdown bench",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "terser": "^5.46.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c"
}
